rules_version = '2';

// ⚠️ Reglas temporales para MVP — recomendación: agregar autenticación luego
service cloud.firestore {
  match /databases/{database}/documents {
    // Amigos: cualquiera puede leer/escribir
    match /friends/{friendId} {
      allow read: if true;
      allow write: if true;
    }

    // Tokens FCM: cualquiera puede leer (para la cloud function)
    // y crear, pero solo el propio token puede ser borrado
    match /fcmTokens/{token} {
      allow read: if true;
      allow create: if true;
      allow delete: if request.auth != null;
      allow write: if request.auth != null;
    }
  }
}
